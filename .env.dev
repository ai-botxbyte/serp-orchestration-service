# ============================================
# Environment Configuration for Dev Deployment
# ============================================
# Copy this file to .env.dev and fill in your values
ENV=dev
# Application Settings
APP_NAME=DemoManagementService
APP_VERSION=2.0.1
APP_PORT=8801
LOG_LEVEL=INFO
SERVICE_NAME=demo-management-service

# ============================================
# Kubernetes Deployment Configuration
# ============================================
KUBE_NAMESPACE=testing
REPLICAS=1
CPU_LIMIT=500m
MEMORY_LIMIT=512Mi
CPU_REQUEST=250m
MEMORY_REQUEST=256Mi
SERVICE_TYPE=ClusterIP

# ============================================
# Database Configuration (Managed Database)
# ============================================
# Format: postgresql+asyncpg://user:password@host:port/database
ASYNC_DATABASE_URL=postgresql+asyncpg://avnadmin:AVNS_r48O7BcFpNja8uocw5w@article-innovator-dev-sanketsakariya2005-0385.e.aivencloud.com:25079/demo_management_db
# Read Replica Database (if using read replica, otherwise same as primary)
ASYNC_READ_DATABASE_URL=postgresql+asyncpg://avnadmin:AVNS_r48O7BcFpNja8uocw5w@article-innovator-dev-sanketsakariya2005-0385.e.aivencloud.com:25079/demo_management_db
IS_USE_READ_REPLICA=false

# ============================================
# Media & Storage Configuration
# ============================================
MEDIA_PATH=app/media
LOGO_SUBDIR=logo

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=*

# =========================================
# Cache & Messaging (Optional)
# ============================================
WASABI_ENDPOINT_URL=https://s3.us-central-1.wasabisys.com
WASABI_ACCESS_KEY_ID=5M5IWDOXB3WSIC1H5KR8
WASABI_SECRET_ACCESS_KEY=1F9gBCUZOg7GO026gMU84JWpV4YP66lRdaKnUMXZ
MIGRATION_BUCKET_NAME=migration-files
WASABI_REGION=us-central-1

# ============================================
# Postgres Configuration
# ============================================
IS_POSTGRES_ENABLED=true
IS_BACKUP_ENABLED=false

# ============================================
# Demo Endpoints
# ============================================
IS_DEMO_ENDPOINTS_ENABLED=false

# ============================================
# Redis Cache Configuration
# ============================================
IS_RABBITMQ_ENABLED=false
IS_QUEUE_LOG=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://guest:guest@localhost:15672
RABBITMQ_QUEUE_NAMES=demo_management_queue,log_queue

# ============================================
# Redis Cache Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
IS_REDIS_CACHE_ENABLED=false
REDIS_CACHE_TTL=300

# ============================================
# APISIX Gateway Configuration
# ============================================
APISIX_ADMIN_URL=http://24.144.64.108:9180
APISIX_ADMIN_API_KEY=edd1c9f034335f136f87ad84b625c8f1
APISIX_JWT_SECRET=oQGHZXprkkSs5DouLIvxfnJ4JzjRk4jk
APISIX_ROUTE_NAME=demo-management-route
IS_APISIX_ENABLED=true

